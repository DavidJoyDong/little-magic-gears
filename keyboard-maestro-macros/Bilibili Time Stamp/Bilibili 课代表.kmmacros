		<key>Macros</key>
		<array>
			<dict>
				<key>Actions</key>
				<array>
					<dict>
						<key>ActionUID</key>
						<integer>16417711</integer>
						<key>DisplayKind</key>
						<string>Variable</string>
						<key>HonourFailureSettings</key>
						<true/>
						<key>IncludeStdErr</key>
						<false/>
						<key>IncludedVariables</key>
						<array>
							<string>9999</string>
						</array>
						<key>MacroActionType</key>
						<string>ExecuteJavaScript</string>
						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>var video = document.querySelector('video');
if (!video) return '';

var totalSeconds = Math.floor(video.currentTime);

var h = Math.floor(totalSeconds / 3600);
var m = Math.floor((totalSeconds % 3600) / 60);
var s = totalSeconds % 60;

var timeText;
if (h &gt; 0) {
  timeText = h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
} else {
  timeText = m + ':' + String(s).padStart(2, '0');
}

return '🕐 ' + totalSeconds + 's ' + timeText;
</string>
						<key>TimeOutAbortsMacro</key>
						<true/>
						<key>TrimResults</key>
						<true/>
						<key>TrimResultsNew</key>
						<true/>
						<key>UseModernSyntax</key>
						<true/>
						<key>UseText</key>
						<true/>
						<key>Variable</key>
						<string>Vedio_TimeStamp</string>
						<key>WebBrowser</key>
						<string>Front Browser</string>
